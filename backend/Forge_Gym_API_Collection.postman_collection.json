				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"currentPassword\": \"password123\",\n    \"newPassword\": \"new_secure_password123\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/change-password",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"auth",
						"change-password"
					]
				},
				"description": "Changes the password of a logged-in user. Requires JWT authorization bearer token."
			},
			"response": []
		},
