		{
			"name": "Auth - Verify OTP",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"if (response.success && response.token) {",
							"    pm.environment.set(\"reset_token\", response.token);",
							"    console.log(\"Saved verification reset_token to environment variables\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"shivamsikarwar7610@gmail.com\",\n    \"otp\": \"123456\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/verify-otp",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"auth",
						"verify-otp"
					]
				},
				"description": "Verifies the 6-digit code received via email. If successful, returns a temporary one-time password reset token which is automatically saved to environment variables."
			},
			"response": []
		},
