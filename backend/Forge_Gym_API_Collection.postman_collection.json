		{
			"name": "Payment - Mock Charge Simulator",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"if (response.success && response.data) {",
							"    pm.environment.set(\"payment_signature\", response.data.signature);",
							"    pm.environment.set(\"payment_txn_id\", response.data.transactionId);",
							"    pm.environment.set(\"payment_status\", response.data.status);",
							"    console.log(\"Saved signature and transaction details to environment variables\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{token}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"orderId\": \"{{order_id}}\",\n    \"action\": \"SUCCEED\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/payments/process-mock-charge",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"payments",
						"process-mock-charge"
					]
				},
				"description": "Simulates payment gateway charge capture. Outcome choices: SUCCEED, FAIL, CANCEL. Generates the necessary cryptographic verification signature."
			},
			"response": []
		},
		{
			"name": "Payment - Secure Verify Signature",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{token}}",
							"type": "string"
						}
					]
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"orderId\": \"{{order_id}}\",\n    \"transactionId\": \"{{payment_txn_id}}\",\n    \"status\": \"{{payment_status}}\",\n    \"signature\": \"{{payment_signature}}\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/payments/verify",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"payments",
						"verify"
					]
				},
				"description": "Verifies the cryptographic HMAC signature associated with the transaction, updating user status and dispatching receipts if successfully completed."
			},
			"response": []
		}
