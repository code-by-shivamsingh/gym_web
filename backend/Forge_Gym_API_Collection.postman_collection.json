						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"shivamsikarwar7610@gmail.com\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/auth/forgot-password",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"auth",
						"forgot-password"
					]
				},
				"description": "Triggers the OTP service. Generates a secure, 6-digit One-Time Password, hashes it in MongoDB, and dispatches an HTML email to the client inbox."
			},
			"response": []
